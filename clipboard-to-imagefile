#!/usr/bin/env bash
# Save clipboard PNG image to timestamped file with optional compression
set -euo pipefail
shopt -s inherit_errexit shift_verbose extglob

declare -r VERSION='1.2.0'
#shellcheck disable=SC2155
declare -r SCRIPT_NAME=$(basename -- "$(realpath -- "$0")")

declare -i COPY_PATH=0

# Logging system
declare -i VERBOSE=1
# Color definitions (if terminal output)
#shellcheck disable=SC2015
[[ -t 1 && -t 2 ]] && declare -r NC=$'\033[0m' RED=$'\033[0;31m' GREEN=$'\033[0;32m' CYAN=$'\033[0;36m' || declare -r NC='' RED='' GREEN='' CYAN=''
# Core message function using FUNCNAME for context
_msg() {
  local -- prefix="$SCRIPT_NAME:" msg
  case ${FUNCNAME[1]} in
    info)    prefix+=" ${CYAN}◉${NC}" ;;
    success) prefix+=" ${GREEN}✓${NC}" ;;
    error)   prefix+=" ${RED}✗${NC}" ;;
  esac
  for msg in "$@"; do printf '%s %s\n' "$prefix" "$msg"; done
}
# Conditional output based on verbosity
info() { ((VERBOSE)) || return 0; >&2 _msg "$@"; }
success() { ((VERBOSE)) || return 0; >&2 _msg "$@" || return 0; }
# Unconditional output
error() { >&2 _msg "$@"; }
die() { (($# < 2)) || error "${@:2}"; exit "${1:-0}"; }

trap 'exit $?' SIGINT SIGTERM EXIT

# --------------------------------------------------------------------------------
# Usage documentation
show_help() {
  cat <<HELP
$SCRIPT_NAME $VERSION - Save clipboard image to PNG file

Save clipboard image to file with timestamp using xclip

Output file is in the form {output_dir}/image-{timestamp}.png

Requires: xclip (pngquant optional for compression)

Usage: $SCRIPT_NAME [OPTIONS] [output_dir]

output_dir        Specifies the output directory for the image.
                  Default /tmp

Options:
  -c, --compress [INT]
                  Compress image using pngquant. Valid range for
                  INT is 20-100. Lower values = higher compression.
                  Defaults to 50 if INT is omitted.
  -p, --copy-path Copy the file path to clipboard after saving
                  Note: this overwrites the image in the clipboard.
  -v, --verbose   Print output filename on completion (default)
  -q, --quiet     Do not print output filename
  -V, --version   Print version and exit
  -h, --help      Display this help

Examples:
  # Copy a screen region first, then run:

  # Create file /tmp/image-20250602-042042.png
  $SCRIPT_NAME

  # Create file ./image-20250602-042042.png
  $SCRIPT_NAME .

  # Create file ~/Downloads/image-20250602-042042.png and compress it
  $SCRIPT_NAME -c ~/Downloads

  # Create very compressed image file and store filename to variable
  imgfile=\$($SCRIPT_NAME -c 30)

  # Save image and copy its path to clipboard for easy sharing
  $SCRIPT_NAME -p ~/Pictures

HELP
}

# Check for required dependencies
check_dependencies() {
  local -i compress=${1:-0}

  if ! command -v xclip &> /dev/null; then
    error 'xclip not installed'
    VERBOSE=1
    info 'Install with:' 'sudo apt update && sudo apt install xclip'
    die 1
  fi

  # Check for pngquant if compression is enabled
  if ((compress)) && ! command -v pngquant &> /dev/null; then
    error 'pngquant not installed (required for compression)'
    VERBOSE=1
    info  'Install with:' 'sudo apt update && sudo apt install pngquant'
    die 1
  fi
}

# Save clipboard image to PNG
save_clipboard_image() {
  local -- output_dir=$1
  local -i compress=${2:-0}

  # Adjust compression boundaries
  ((compress > 19)) || compress=20
  local -i upperbound=compress+15

  local -- timestamp=$(date +'%Y%m%d-%H%M%S')
  local -- filename=image-"$timestamp".png
  local -- filepath="$output_dir"/"$filename"

  # Check if clipboard contains a PNG image
  xclip -selection clipboard -t TARGETS -o 2>/dev/null | grep -q 'image/png' \
      || die 1 'No image found in clipboard'

  # Get image from clipboard and save directly to file
  xclip -selection clipboard -t image/png -o > "$filepath" 2>/dev/null || die 1 'Failed to save clipboard content as image'

  # Apply compression if requested
  ((compress==0)) || pngquant --quality=${compress}-${upperbound} --force --ext .png "$filepath"

  # Check if the file was created and has content
  if [[ -s "$filepath" ]]; then
    # Copy path to clipboard if requested
    if ((COPY_PATH)); then
      # Write file path as text to clipboard, replacing the image data
      echo -n "$filepath" | xclip -selection clipboard -i 2>/dev/null
      info 'File path copied to clipboard'
    fi

    # Always output the filepath to stdout (unless quiet mode is on)
    ((VERBOSE==0)) || echo "$filepath"
    return 0
  fi

  # Clean up empty file if it was created
  rm -f "$filepath"
  die 1 'Failed to save clipboard content as image'
}

# --------------------------------------------------------------------------------
main() {
  local -- output_dir=''
  local -i compress=0

  # Argument parsing
  while (($#)); do case $1 in
    -h|--help)      show_help; return 0 ;;
    -V|--version)   echo "$SCRIPT_NAME $VERSION"; return 0 ;;

    -c|--compress)  shift
                    if (($#)) && [[ ${1:0:1} != '-' ]] && [[ $1 =~ ^[0-9]+$ ]]; then
                      compress=$1
                    else
                      compress=50
                      continue
                    fi
                    ;;
    -p|--copy-path) COPY_PATH=1 ;;
    -v|--verbose)   VERBOSE+=1 ;;
    -q|--quiet)     VERBOSE=0 ;;
    -[hVcpvq]?*) # Bundled short options
                    set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
    -*)             die 22 "Invalid option ${1@Q}" ;;
    *)              [[ -z $output_dir ]] || die 2 "Too many arguments ${1@Q}" "Output dir ${output_dir@Q} already specified."
                    output_dir=$1 ;;
  esac; shift; done

  # Set default output directory
  [[ -n $output_dir ]] || output_dir=/tmp

  # Resolve and validate output directory
  output_dir=$(realpath -- "$output_dir") || die 1 "Output directory ${output_dir@Q} does not exist"
  [[ -d "$output_dir" ]] || die 1 "Output directory ${output_dir@Q} does not exist"

  # Check dependencies
  check_dependencies "$compress"

  # Save clipboard image
  save_clipboard_image "$output_dir" "$compress"
}

main "$@"
#fin
